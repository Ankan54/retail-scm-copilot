# SupplyChain Copilot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ----------------------------
# PostgreSQL (AWS RDS)
# ----------------------------
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=supplychain
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=require

# ----------------------------
# AWS
# ----------------------------
AWS_ACCOUNT_ID=your_aws_account_id
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# ----------------------------
# Bedrock
# ----------------------------
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_AGENT_ID=your_supervisor_agent_id
BEDROCK_AGENT_ALIAS_ID=your_supervisor_agent_alias_id

# ----------------------------
# Telegram Bot (get token from @BotFather)
# ----------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=generate_with_scripts/register_telegram_webhook.py
