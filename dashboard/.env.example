# SupplyChain Copilot — Dashboard Environment Variables
# Copy this file to .env and fill in your values.
# Vite exposes only VITE_* prefixed variables to the browser bundle.
# Never commit .env to version control.

# API Gateway base URL (all /api/* REST endpoints)
VITE_API_BASE=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Lambda Function URL for AI chat (bypasses API Gateway 29s timeout)
VITE_STREAMING_URL=https://your-function-url.lambda-url.us-east-1.on.aws/
